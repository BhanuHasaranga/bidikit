{
  "name": "@bidikit/tailwind",
  "version": "1.1.0",
  "description": "Tailwind CSS plugin for BidiKit - logical properties, rtl:/ltr: variants",
  "keywords": [
    "rtl",
    "ltr",
    "tailwind",
    "tailwindcss",
    "plugin",
    "logical-properties",
    "bidi"
  ],
  "license": "MIT",
  "author": "BhanuHasaranga",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhanuHasaranga/bidikit.git",
    "directory": "packages/tailwind"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist coverage"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
