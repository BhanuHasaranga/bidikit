{
  "name": "@bidikit/core",
  "version": "1.0.0",
  "description": "Zero-dependency RTL/LTR engine — The missing layer for bidirectional web applications",
  "keywords": ["rtl", "ltr", "bidi", "bidirectional", "i18n", "internationalization", "arabic", "hebrew", "direction"],
  "license": "MIT",
  "author": "BhanuHasaranga",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhanuHasaranga/bidikit.git",
    "directory": "packages/core"
  },
  "homepage": "https://bidikit.dev",
  "bugs": { "url": "https://github.com/BhanuHasaranga/bidikit/issues" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
