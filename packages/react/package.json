{
  "name": "@bidikit/react",
  "version": "1.1.0",
  "description": "React hooks and components for BidiKit — RTL/LTR direction-aware UI",
  "keywords": [
    "rtl",
    "ltr",
    "bidi",
    "react",
    "hooks",
    "components",
    "i18n",
    "direction"
  ],
  "license": "MIT",
  "author": "BhanuHasaranga",
  "repository": {
    "type": "git",
    "url": "https://github.com/BhanuHasaranga/bidikit.git",
    "directory": "packages/react"
  },
  "homepage": "https://bidikit.dev",
  "bugs": {
    "url": "https://github.com/BhanuHasaranga/bidikit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@bidikit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
