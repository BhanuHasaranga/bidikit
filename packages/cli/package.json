{
  "name": "@bidikit/cli",
  "version": "1.1.0",
  "description": "CLI tooling for BidiKit — init, add, doctor, extract, sync, lint",
  "keywords": [
    "rtl",
    "ltr",
    "bidi",
    "cli",
    "i18n",
    "translation",
    "scaffolding"
  ],
  "license": "MIT",
  "author": "BhanuHasaranga",
  "type": "module",
  "bin": {
    "bidikit": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
